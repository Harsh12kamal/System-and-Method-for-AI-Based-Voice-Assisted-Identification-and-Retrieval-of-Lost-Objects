

import pandas as pd
import numpy as np
import datetime
import re
import os
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.linear_model import LogisticRegression



DB_FILE = "memory_store.csv"

if not os.path.exists(DB_FILE):
    df_init = pd.DataFrame(columns=["item", "location", "timestamp", "confidence"])
    df_init.to_csv(DB_FILE, index=False)

print("System Ready ✅")
print("Type 'exit' to stop.\n")



find_samples = [
    "where is my wallet", "where did i keep my keys",
    "find my laptop", "can you find my phone",
    "i lost my wallet", "locate my glasses",
    "where are my keys", "help me find my charger",
    "do you know where my bag is",
    "i cannot find my headphones",
    "where did i leave my watch",
    "search for my tablet",
    "any idea where my camera is",
    "tell me where my passport is",
    "where did i place my book",
    "find my notebook",
    "where are my shoes",
    "track my wallet",
    "what is the location of my laptop",
    "where is my umbrella",
] * 5   # 20 × 5 = 100 samples

update_samples = [
    "i left my wallet on the table",
    "i kept my keys in kitchen",
    "i placed my laptop on desk",
    "my phone is in bedroom",
    "i put my bag near sofa",
    "wallet is on study table",
    "keys are in drawer",
    "laptop is at office",
    "i dropped my charger on bed",
    "glasses are on shelf",
    "i stored my passport in locker",
    "watch is on table",
    "i put my tablet in backpack",
    "camera is in cupboard",
    "i kept my shoes near door",
    "book is on rack",
    "notebook is in bag",
    "umbrella is near entrance",
    "headphones are on desk",
    "i placed my phone on chair"
] * 5   # 20 × 5 = 100 samples

training_sentences = find_samples + update_samples
training_labels = ["FIND"] * len(find_samples) + ["UPDATE"] * len(update_samples)

vectorizer = TfidfVectorizer()
X_train = vectorizer.fit_transform(training_sentences)

intent_model = LogisticRegression(max_iter=1000)
intent_model.fit(X_train, training_labels)


def detect_intent(text):
    X_test = vectorizer.transform([text])
    return intent_model.predict(X_test)[0]



def extract_item(text):
    # Extract word after "my"
    match = re.search(r"my (\w+)", text.lower())
    return match.group(1) if match else None


def extract_location(text):
    match = re.search(r"(on|in|at|near) ([a-zA-Z ]+)", text.lower())
    return match.group(2).strip() if match else None




def update_memory(item, location):
    df = pd.read_csv(DB_FILE)

    current_time = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    new_entry = {
        "item": item,
        "location": location,
        "timestamp": current_time,
        "confidence": 0.9
    }

    df = pd.concat([df, pd.DataFrame([new_entry])], ignore_index=True)
    df.to_csv(DB_FILE, index=False)

    print(f"AI: Noted ✅ Your {item} is recorded at {location}.")




def predict_location(item):
    df = pd.read_csv(DB_FILE)

    if df.empty:
        return None, 0

    df["timestamp"] = pd.to_datetime(df["timestamp"], format="mixed")

    item_data = df.loc[df["item"] == item].copy()

    if item_data.empty:
        return None, 0

    current_time = datetime.datetime.now()

    item_data["time_diff"] = (
        current_time - item_data["timestamp"]
    ).dt.total_seconds()

    # Balanced scoring: confidence + recency
    item_data["score"] = (
        0.6 * item_data["confidence"] +
        0.4 * np.exp(-item_data["time_diff"] / 200000)
    )

    best_row = item_data.sort_values("score", ascending=False).iloc[0]

    return best_row["location"], float(best_row["score"])



while True:
    user_input = input("You: ")

    if user_input.lower() == "exit":
        print("System Closed 👋")
        break

    intent = detect_intent(user_input)
    item = extract_item(user_input)
    location = extract_location(user_input)

    if not item:
        print("AI: I could not identify the item. Please mention it clearly.")
        continue

    if intent == "FIND":
        predicted_location, score = predict_location(item)

        if predicted_location:
            print(f"AI: Your {item} was last seen at {predicted_location}.")
            print(f"Confidence Score: {round(score,3)}")
        else:
            print(f"AI: I do not have prior data about your {item}. Please update its location first.")

    elif intent == "UPDATE":
        if location:
            update_memory(item, location)
        else:
            print("AI: I detected an update but could not identify the location.")
